generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String
  phone        String?       // E.164 format e.g. +12125551234
  role         String        @default("PLAYER") // PLAYER | ORGANIZER
  balance      Decimal  @default(0) @db.Decimal(12, 2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  organizedTables     Table[]             @relation("OrganizerTables")
  tablePlayers        TablePlayer[]
  ledgerEntries       LedgerEntry[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique  // 6-digit SMS code (stored hashed) or long hex token
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model LedgerEntry {
  id          String   @id @default(uuid())
  amount      Decimal  @db.Decimal(12, 2)
  type        String   // DEPOSIT | BUY_IN | CASH_OUT
  description String?
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Table {
  id          String   @id @default(uuid())
  name        String
  maxPlayers  Int      @default(9)
  buyInAmount  Decimal  @db.Decimal(12, 2)
  status      String   @default("OPEN") // OPEN | CLOSED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payoutSummary Json?

  organizerId String
  organizer   User   @relation("OrganizerTables", fields: [organizerId], references: [id])

  chipDenominations ChipDenomination[]
  players           TablePlayer[]
}

model ChipDenomination {
  id      String @id @default(uuid())
  color   String // hex color code
  label   String // e.g. "White", "Red"
  value   Decimal  @db.Decimal(12, 2)

  tableId String
  table   Table  @relation(fields: [tableId], references: [id], onDelete: Cascade)
}

model TablePlayer {
  id            String   @id @default(uuid())
  status        String   @default("PENDING") // PENDING | ACTIVE | CASHED_OUT
  rebuys        Int      @default(0)        // number of additional buy-ins after the first
  cashoutAmount Decimal? @db.Decimal(12, 2)
  stackPhoto    String?  // Cloudflare R2 public URL (previously base64, migrated)
  chipCounts    Json?    // [{ color, label, value, count }] — ML training labels
  joinedAt      DateTime @default(now())

  tableId String
  table   Table  @relation(fields: [tableId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([tableId, userId])
}
